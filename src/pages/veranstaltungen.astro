---
import Layout from '../layouts/Layout.astro';
import CalendarSubscription from '../components/CalendarSubscription.astro';
import { veranstaltungen } from '../data/veranstaltungen';

function parseDate(dateString: string) {
  const [day, month, year] = dateString.split('.').map(x => parseInt(x));
  return new Date(year, month - 1, day).getTime();
}

function toIsoDate(datum: string): string {
  const [day, month, year] = datum.split('.');
  return `${year}-${month}-${day}`;
}

const sortedEvents = [...veranstaltungen].sort((a, b) => parseDate(a.datum) - parseDate(b.datum));
---

<Layout
  title="Veranstaltungen"
  teaserImage="/images/veranstaltungen.jpg"
  teaserPosition="50% 38%"
  teaserAltText="Willkommen beim Obst- und Gartenbauverein Pattenhofen Altenthann e.V."
>
  <h1>Jahresprogramm 2026</h1>
  <table id="eventsTable" style="margin-bottom: 1rem">
    {sortedEvents.map((event) => (
      <tr data-date={toIsoDate(event.datum)}>
        <td style="white-space: nowrap; vertical-align: top;">
          {event.datum}
        </td>
        <td>{event.titel}</td>
      </tr>
    ))}
  </table>


  <button id="togglePastEvents" class="toggle-button">
      Vergangene Veranstaltungen anzeigen
    </button>
  <div class="past-events-section" id="pastEventsSection">
    
  </div>

  <p>
    Weitere Veranstaltungen die noch nicht terminiert sind werden rechtzeitig in
    der Tageszeitung veröffentlicht.
  </p>

  <CalendarSubscription icsUrl="/veranstaltungen.ics" />
</Layout>

<style lang="scss">
  @use "../styles/minima/variables" as *;

  .past-events-section {
    margin-top: $spacing-unit;
    display: none;
  }

  .toggle-button {
    padding: 8px 16px;
    background-color: $grey-color-light;
    border: 1px solid $grey-color;
    border-radius: 4px;
    color: $text-color;
    font-size: $base-font-size;
    font-weight: 500;
    margin-bottom: 1rem;
    cursor: pointer;

    &:hover {
      background-color: $grey-color;
      color: #fff;
    }
  }

  tr.past-event {
    display: none;
    opacity: 0.6;
  }

  tr.past-event.visible {
    display: table-row;
  }
</style>

<script>
  const today = new Date();
  const todayStart = new Date(today.getFullYear(), today.getMonth(), today.getDate()).getTime();

  const rows = Array.from(document.querySelectorAll<HTMLTableRowElement>('#eventsTable tr[data-date]'));
  const pastRows: HTMLTableRowElement[] = [];

  rows.forEach(row => {
    const [year, month, day] = row.dataset.date!.split('-').map(Number);
    if (new Date(year, month - 1, day).getTime() < todayStart) {
      row.classList.add('past-event');
      pastRows.push(row);
    }
  });

  const pastSection = document.getElementById('pastEventsSection');
  if (pastRows.length > 0 && pastSection) {
    pastSection.style.display = '';
  }

  const toggleButton = document.getElementById('togglePastEvents');
  if (toggleButton) {
    toggleButton.addEventListener('click', () => {
      const isShowing = toggleButton.textContent?.includes('verbergen');
      pastRows.forEach(row => row.classList.toggle('visible', !isShowing));
      toggleButton.textContent = isShowing
        ? 'Vergangene Veranstaltungen anzeigen'
        : 'Vergangene Veranstaltungen verbergen';
    });
  }
</script>
